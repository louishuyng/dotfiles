[
  {
    "bindings": {
      "cmd-s": "workspace::ToggleRightDock"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // General
      "space w": "workspace::Save",
      "space q": "pane::CloseActiveItem",
      // File Explore
      "ctrl-p": "file_finder::Toggle",
      "space /": "workspace::NewSearch",
      // Split
      ", v": "pane::SplitRight",
      ", s": "pane::SplitUp",
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      // Buffer
      ", q": "pane::ActivatePreviousItem",
      ", w": "pane::ActivateNextItem",
      ", b d": "pane::CloseActiveItem",
      ", b d a": "pane::CloseAllItems",
      // Temrinal
      "ctrl-t": "workspace::NewTerminal",
      // LSP
      "g f": "editor::GoToDefinition",
      "g t": "editor::GoToTypeDefinition",
      "g v": "editor::GoToDefinitionSplit",
      // Git
      ", g b": "git::Blame",
      "space g b": "editor::ToggleGitBlameInline",
      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",
      // Collapse sidebar workspace
      "ctrl-\\": "project_panel::ToggleFocus",
      "space s": "outline_panel::ToggleFocus",
      ", g s": "git_panel::ToggleFocus",
      // Code Action
      "space c a": "editor::ToggleCodeActions",
      // Find all word matc hbelow cursor
      "ctrl-n": "editor::SelectAllMatches",

      // Diagnostic
      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic"

      // TODO:
      // Run Test
      // Run Test in current cursor
      // Run Test in current file
    }
  },
  {
    // Folder Sidebar
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "ctrl-\\": "workspace::ToggleLeftDock",
      // Add new file
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      // Delete file
      "D": "project_panel::Delete",
      // Rename file
      "r": "project_panel::Rename",
      "l": "project_panel::OpenPermanent"
    }
  },
  {
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrevious",
      "ctrl-n": "menu::SelectNext",
      "ctrl-p": "menu::SelectPrevious"
    }
  },
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "ctrl-j": "editor::ContextMenuNext",
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-n": "editor::ContextMenuNext",
      "ctrl-p": "editor::ContextMenuPrevious"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    // Editor
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space k": "assistant::InlineAssist",
      "space i": "agent::ToggleFocus"
    }
  },
  {
    "context": "Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "GitPanel > Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "OutlinePanel > Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      // Close terminal
      "ctrl-t": "pane::CloseActiveItem",
      "ctrl-l": "terminal::Clear"
    }
  },
  {
    "bindings": {
      "cmd-/": "agent::ToggleFocus"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-a s": [
        "projects::OpenRecent",
        {
          "create_new_window": false
        }
      ]
    }
  },
  {
    "context": "(ProjectPanel && not_editing)",
    "bindings": {
      "s": "project_panel::OpenSplitHorizontal"
    }
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space h p": "editor::ToggleSelectedDiffHunks"
    }
  },
  {
    "context": "((Editor && !agent_diff) && !AgentPanel) && vim_mode == normal",
    "bindings": {
      "space h u": "git::UnstageAndNext"
    }
  },
  {
    "context": "(GitPanel && ChangesList)",
    "bindings": {
      "s": "git::StageFile"
    }
  },
  {
    "context": "GitDiff > Editor",
    "bindings": {
      "shift-s": "git::StageAll"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-\\": "project_panel::ToggleFocus"
    }
  },
  {
    "context": "((Editor && !agent_diff) && !AgentPanel) && vim_mode == normal",
    "bindings": {
      "space h s": "git::ToggleStaged",
      "space h r": "git::Restore"
    }
  },
  {
    // Debug (DAP)
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space d b": "editor::ToggleBreakpoint",
      "space d d": "debugger::Start",
      "space d c": "debugger::Continue",
      "space d C": "debugger::RunToCursor",
      "space d i": "debugger::StepInto",
      "space d o": "debugger::StepOut",
      "space d O": "debugger::StepOver",
      "space d t": "debugger::Stop",
      "space d r": "debugger::Restart",
      "space d u": "debug_panel::ToggleFocus"
    }
  },
  {
    // Test
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space t s": "editor::SpawnNearestTask",
      "space t f": "task::Spawn",
      "space t l": "task::Rerun",
      ", a": ["task::Spawn", { "task_name": "Toggle Test File" }]
    }
  }
]
