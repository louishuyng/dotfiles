#!/opt/homebrew/bin/bash

source "$CONFIG_DIR/colors.sh"

PLUGIN_DIR="$CONFIG_DIR/plugins"
ITEM_DIR="$CONFIG_DIR/items"

# CPU helper: autonomous Mach-based daemon that pushes cpu% to the `cpu` item.
# Replaces the per-tick `top -l 2` shell poll (~1s blocking every 5s).
killall helper >/dev/null 2>&1
"$CONFIG_DIR/helper/helper" >/dev/null 2>&1 &

##### Bar Appearance #####
sketchybar --bar position=bottom height=32 \
                 color=$BAR_COLOR \
                 border_width=0 \
                 corner_radius=0 \
                 margin=0 \
                 padding_left=0 \
                 padding_right=0 \
                 shadow=off \
                 sticky=on \
                 topmost=window \
                 y_offset=0 \


##### Changing Defaults #####
default=(
	icon.font="Terminess Nerd Font:Regular:16.0"
	icon.color=$TEXT_COLOR
	label.font="Terminess Nerd Font:Regular:16.0"
	label.color=$TEXT_COLOR
	padding_left=5
	padding_right=5
	background.drawing=off
)
sketchybar --default "${default[@]}"

##### Adding items #####
sketchybar --add event aerospace_workspace_change

sketchybar --add event theme_change "AppleInterfaceThemeChangedNotification"
sketchybar --add item theme_listener left \
           --set theme_listener script="$PLUGIN_DIR/theme_change.sh" \
                                drawing=off \
           --subscribe theme_listener theme_change

source "$ITEM_DIR/pulse.sh"
source "$ITEM_DIR/workspace.sh"
# source "$ITEM_DIR/separator.sh"
source "$ITEM_DIR/front_app.sh"

# Right side — order = rightmost first
source "$ITEM_DIR/clock.sh"
source "$ITEM_DIR/battery.sh"
source "$ITEM_DIR/network.sh"
source "$ITEM_DIR/cpu.sh"
source "$ITEM_DIR/spotify.sh"

##### Force all scripts to run the first time #####
sketchybar --update

##### Initialize workspace states on startup #####
FOCUSED_WS=$(aerospace list-workspaces --focused 2>/dev/null)
for ws in $(aerospace list-workspaces --monitor all --empty no 2>/dev/null); do
	NAME="workspace.$ws" FOCUSED_WORKSPACE="$FOCUSED_WS" \
		bash "$CONFIG_DIR/plugins/workspace.sh"
done
